# =====================================================================
# .gitignore — agnostico, da estendere quando si decide lo stack
# in docs/STACK-TECNICO.md (FASE C)
# =====================================================================

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
nul

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# =====================================================================
# Python (se useremo Python)
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
venv/
.venv/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# =====================================================================
# Node.js (se useremo Node/JS)
# =====================================================================
node_modules/
dist/
build/
.next/
.nuxt/
.vite/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.parcel-cache/
*.tsbuildinfo

# =====================================================================
# Database locali (da rivedere in STACK-TECNICO.md)
# =====================================================================
*.sqlite
*.sqlite3
*.db
!data/*.json

# =====================================================================
# File runtime / upload locali (da definire)
# =====================================================================
uploads/
tmp/
.tmp/

# PdE input file: i file Numbers/Excel del Programma di Esercizio sono
# dati commerciali (decine di MB, cambiano ogni anno). L'utente li tiene
# sul proprio Mac e li punta via CLI. La fixture mini per i test vive
# in backend/tests/fixtures/ ed è committata.
backend/data/pde-input/*
!backend/data/pde-input/README.md

# =====================================================================
# Claude Code
# =====================================================================
.claude/


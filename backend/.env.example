# Backend env example — copia in .env.local e personalizza
# Vedi docs/STACK-TECNICO.md §6 per descrizione completa.

# --- App ---
LOG_LEVEL=INFO
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql+psycopg://colazione:colazione@localhost:5432/colazione

# --- Auth (Sprint 2) ---
JWT_SECRET=dev-secret-change-me-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MIN=4320
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Admin bootstrap (Sprint 2) ---
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=

# --- CORS (Sprint 0) ---
CORS_ALLOW_ORIGINS=http://localhost:5173

# --- Multi-tenant default ---
DEFAULT_AZIENDA=trenord
